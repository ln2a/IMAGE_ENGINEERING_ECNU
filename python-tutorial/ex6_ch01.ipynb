      "source": [
        "# 逆问题：从观测 y 估计真实图像 x\n",
        "# 去噪：y = x + n\n",
        "# 去模糊：y = k \\* x + n\n",
        "# 超分辨率：y = D x + n\n",
        "# 核心思想：\n",
        "# min ||A x - y||^2 + lambda R (x)\n",
        "print (\"Denoising removes added noise.\")\n",
        "print (\"Deblurring recovers mixed details.\")\n",
        "print (\"Super-resolution infers missing details.\")"
      ]
    }
